APP_ENV=production

# Copy this file to `.env.vps` on the VPS and replace every secret value.
POSTGRES_DB=meeting_execution_agent
POSTGRES_USER=meeting_agent
POSTGRES_PASSWORD=change-this-vps-password
POSTGRES_PORT_BIND=127.0.0.1:5432

DATABASE_URL=postgresql://meeting_agent:change-this-vps-password@localhost:5432/meeting_execution_agent
REDIS_URL=redis://localhost:6379/0
REDIS_PORT_BIND=127.0.0.1:6379

