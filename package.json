{
  "name": "meeting-execution-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "api:dev": "uv run --directory services/agent-api uvicorn app.main:app --reload",
    "build": "pnpm --filter @meeting-execution-agent/web build",
    "check": "pnpm --filter @meeting-execution-agent/web check",
    "infra:local:config": "docker compose -p meeting-execution-agent-local -f infra/compose.db.yml config",
    "infra:local:down": "docker compose -p meeting-execution-agent-local -f infra/compose.db.yml down",
    "infra:local:logs": "docker compose -p meeting-execution-agent-local -f infra/compose.db.yml logs -f",
    "infra:local:ps": "docker compose -p meeting-execution-agent-local -f infra/compose.db.yml ps",
    "infra:local:refresh": "docker compose -p meeting-execution-agent-local -f infra/compose.db.yml pull && docker compose -p meeting-execution-agent-local -f infra/compose.db.yml up -d --force-recreate --remove-orphans",
    "infra:local:reset": "docker compose -p meeting-execution-agent-local -f infra/compose.db.yml down -v",
    "infra:local:restart": "docker compose -p meeting-execution-agent-local -f infra/compose.db.yml restart",
    "infra:local:stop": "docker compose -p meeting-execution-agent-local -f infra/compose.db.yml stop",
    "infra:local:up": "docker compose -p meeting-execution-agent-local -f infra/compose.db.yml up -d",
    "infra:vps:config": "docker compose --env-file .env.vps -p meeting-execution-agent-vps -f infra/compose.db.yml config",
    "infra:vps:down": "docker compose --env-file .env.vps -p meeting-execution-agent-vps -f infra/compose.db.yml down",
    "infra:vps:logs": "docker compose --env-file .env.vps -p meeting-execution-agent-vps -f infra/compose.db.yml logs -f",
    "infra:vps:ps": "docker compose --env-file .env.vps -p meeting-execution-agent-vps -f infra/compose.db.yml ps",
    "infra:vps:refresh": "docker compose --env-file .env.vps -p meeting-execution-agent-vps -f infra/compose.db.yml pull && docker compose --env-file .env.vps -p meeting-execution-agent-vps -f infra/compose.db.yml up -d --force-recreate --remove-orphans",
    "infra:vps:reset": "docker compose --env-file .env.vps -p meeting-execution-agent-vps -f infra/compose.db.yml down -v",
    "infra:vps:restart": "docker compose --env-file .env.vps -p meeting-execution-agent-vps -f infra/compose.db.yml restart",
    "infra:vps:stop": "docker compose --env-file .env.vps -p meeting-execution-agent-vps -f infra/compose.db.yml stop",
    "infra:vps:up": "docker compose --env-file .env.vps -p meeting-execution-agent-vps -f infra/compose.db.yml up -d",
    "lint:python": "uv run --all-packages ruff check packages services",
    "test:python": "uv run --all-packages pytest",
    "verify": "pnpm build && pnpm check && pnpm lint:python && pnpm test:python",
    "web:dev": "pnpm --filter @meeting-execution-agent/web dev",
    "worker:dev": "uv run --directory services/worker python -m app.main"
  }
}
