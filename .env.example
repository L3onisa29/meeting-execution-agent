APP_ENV=local

# Web
WEB_BASE_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me
INTERNAL_JWT_SECRET=change-me
INTERNAL_JWT_ISSUER=web
INTERNAL_JWT_AUDIENCE=agent-api

# Agent API
AGENT_API_BASE_URL=http://localhost:8000

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=meeting-execution-agent

# Data services
POSTGRES_DB=meeting_execution_agent
POSTGRES_USER=meeting_agent
POSTGRES_PASSWORD=meeting_agent
POSTGRES_PORT_BIND=127.0.0.1:5432
DATABASE_URL=postgresql://meeting_agent:meeting_agent@localhost:5432/meeting_execution_agent
REDIS_URL=redis://localhost:6379/0
REDIS_PORT_BIND=127.0.0.1:6379

